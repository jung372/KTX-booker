# ────────────────────────────────────────────────────
#  K-Reservation Bot 환경변수 설정 예시
#  이 파일을 복사하여 .env 로 저장 후 값을 채우세요.
#  .env 파일은 .gitignore 로 추적되지 않습니다.
#
#  GitHub Actions 사용 시:
#    Settings → Secrets and variables → Actions → New repository secret
#    에서 아래 키-값을 각각 추가하세요.
# ────────────────────────────────────────────────────

# 코레일 계정
KORAIL_ID=your_korail_id
KORAIL_PW=your_korail_password

# 텔레그램 알림 (선택)
TELEGRAM_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# 1순위 여정 (GitHub Actions workflow_dispatch 입력으로도 전달 가능)
JOURNEY_DEP_STATION=서울
JOURNEY_ARR_STATION=부산
JOURNEY_DATE=2025-05-01
JOURNEY_TIME=07:00
